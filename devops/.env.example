# ── 数据库 ──────────────────────────────────────────
POSTGRES_USER=tourmind
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=tourmind
DATABASE_URL=postgresql+asyncpg://tourmind:change_me_in_production@db:5432/tourmind

# ── JWT ─────────────────────────────────────────────
SECRET_KEY=replace_with_64_char_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480       # 8h
REMEMBER_TOKEN_EXPIRE_MINUTES=10080   # 7d

# ── 文件上传 ─────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10

# ── 其他 ─────────────────────────────────────────────
DEBUG=false
CORS_ORIGINS=["http://localhost:5173","https://yourdomain.com"]
